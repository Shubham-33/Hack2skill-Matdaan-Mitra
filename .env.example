# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini API key — get one at https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=

# Google (OAuth client credentials live in credentials.json / token.json)
GOOGLE_SHEETS_ID=
GOOGLE_SLIDES_ID=

# Slack (for webhook activity streaming)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# Modal (set via `modal token set` rather than env, but listed for visibility)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
